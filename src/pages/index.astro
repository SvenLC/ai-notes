---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const cases = (await getCollection("cases", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const siteUrl = Astro.site?.toString() ?? "";
const description =
  "Open library of real-world human-AI collaboration case files. Rigorous, documented, double-readable for humans and AI agents.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      name: "ai-notes",
      url: siteUrl,
      description,
      inLanguage: "en",
      publisher: { "@id": `${siteUrl}#publisher` },
    },
    {
      "@type": "Blog",
      "@id": `${siteUrl}#blog`,
      isPartOf: { "@id": `${siteUrl}#website` },
      name: "ai-notes",
      url: siteUrl,
      description,
      inLanguage: "en",
      publisher: { "@id": `${siteUrl}#publisher` },
      blogPost: cases.map((entry) => ({
        "@type": "BlogPosting",
        headline: entry.data.title,
        description: entry.data.summary,
        datePublished: entry.data.date.toISOString(),
        inLanguage: entry.data.language,
        url: new URL(`/cases/${entry.slug}/`, Astro.site).toString(),
      })),
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}#publisher`,
      name: "Sven Le Cann",
      url: "https://svenlc.com",
      sameAs: ["https://github.com/SvenLC"],
    },
  ],
};
---

<BaseLayout title="ai-notes" description={description}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>
  <section class="intro">
    <h1>Case files of human-AI collaboration.</h1>
    <p>
      Open library of real-world situations where an AI was put to work under a human frame. Every
      case follows the same format: problem, AI role, human role, corrections, what couldn't be
      delegated, pattern, counter-indications.
    </p>
  </section>

  {cases.length === 0 ? (
    <p class="empty">No case files published yet.</p>
  ) : (
    <ul class="cases">
      {cases.map((entry) => (
        <li>
          <article>
            <p class="meta">
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                  timeZone: "UTC",
                })}
              </time>
              <span>&middot;</span>
              <span>{entry.data.domain.join(" · ")}</span>
            </p>
            <h2>
              <a href={`/cases/${entry.slug}/`}>{entry.data.title}</a>
            </h2>
            <p class="summary">{entry.data.summary}</p>
          </article>
        </li>
      ))}
    </ul>
  )}

  <style>
    .intro {
      margin-bottom: 3rem;
    }

    .intro h1 {
      font-size: 1.9rem;
      margin: 0 0 1rem 0;
    }

    .intro p {
      color: var(--color-muted);
      margin: 0;
    }

    .cases {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .cases li {
      padding: 1.5rem 0;
      border-top: 1px solid var(--color-border);
    }

    .cases li:last-child {
      border-bottom: 1px solid var(--color-border);
    }

    .meta {
      font-family: var(--font-meta);
      font-size: 0.8rem;
      color: var(--color-muted);
      margin: 0 0 0.35rem 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .cases h2 {
      margin: 0 0 0.35rem 0;
      font-size: 1.15rem;
    }

    .cases h2 a {
      text-decoration: none;
      color: var(--color-fg);
    }

    .cases h2 a:hover {
      text-decoration: underline;
    }

    .summary {
      margin: 0;
      color: var(--color-muted);
      font-size: 0.95rem;
    }

    .empty {
      color: var(--color-muted);
      font-style: italic;
    }
  </style>
</BaseLayout>
