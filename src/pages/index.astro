---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const cases = (await getCollection("cases", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="ai-notes">
  <section class="intro">
    <h1>Cas de collaboration humain-IA.</h1>
    <p>
      Bibliothèque ouverte de situations réelles où une IA a été mise au travail avec un cadre
      humain. Chaque cas suit un même format&nbsp;: problème, rôle de l'IA, rôle de l'humain,
      corrections, non-déléguable, pattern, contre-indications.
    </p>
  </section>

  {cases.length === 0 ? (
    <p class="empty">Aucun cas publié pour le moment.</p>
  ) : (
    <ul class="cases">
      {cases.map((entry) => (
        <li>
          <article>
            <p class="meta">
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString("fr-FR", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                  timeZone: "UTC",
                })}
              </time>
              <span>&middot;</span>
              <span>{entry.data.domain.join(" · ")}</span>
            </p>
            <h2>
              <a href={`/cases/${entry.slug}/`}>{entry.data.title}</a>
            </h2>
            <p class="summary">{entry.data.summary}</p>
          </article>
        </li>
      ))}
    </ul>
  )}

  <style>
    .intro {
      margin-bottom: 3rem;
    }

    .intro h1 {
      font-size: 1.9rem;
      margin: 0 0 1rem 0;
    }

    .intro p {
      color: var(--color-muted);
      margin: 0;
    }

    .cases {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .cases li {
      padding: 1.5rem 0;
      border-top: 1px solid var(--color-border);
    }

    .cases li:last-child {
      border-bottom: 1px solid var(--color-border);
    }

    .meta {
      font-family: var(--font-meta);
      font-size: 0.8rem;
      color: var(--color-muted);
      margin: 0 0 0.35rem 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .cases h2 {
      margin: 0 0 0.35rem 0;
      font-size: 1.15rem;
    }

    .cases h2 a {
      text-decoration: none;
      color: var(--color-fg);
    }

    .cases h2 a:hover {
      text-decoration: underline;
    }

    .summary {
      margin: 0;
      color: var(--color-muted);
      font-size: 0.95rem;
    }

    .empty {
      color: var(--color-muted);
      font-style: italic;
    }
  </style>
</BaseLayout>
