---
interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = "Open library of real-world human-AI collaboration case files.",
  ogType = "website",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="ai-notes" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="llms-full.txt" href="/llms-full.txt" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="ai-notes" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">ai-notes</a>
      <nav>
        <a href="/">Case files</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        <a href="https://github.com/SvenLC/ai-notes">Source on GitHub</a>
        &middot;
        Content CC BY-SA 4.0
        &middot;
        Code MIT
      </p>
    </footer>
    <style is:global>
      :root {
        --font-body: ui-serif, Georgia, "Times New Roman", serif;
        --font-meta: ui-sans-serif, system-ui, -apple-system, sans-serif;
        --font-mono: ui-monospace, SFMono-Regular, Menlo, monospace;
        --color-bg: #fafaf8;
        --color-fg: #17171a;
        --color-muted: #6b6b70;
        --color-border: #e4e4e0;
        --color-accent: #17171a;
        --measure: 36rem;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--color-bg);
        color: var(--color-fg);
        font-family: var(--font-body);
        font-size: 18px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--color-border);
        font-family: var(--font-meta);
        font-size: 0.9rem;
      }

      .site-title {
        font-weight: 600;
        text-decoration: none;
        color: var(--color-fg);
      }

      nav a {
        margin-left: 1.5rem;
        color: var(--color-muted);
        text-decoration: none;
      }

      nav a:hover {
        color: var(--color-fg);
      }

      main {
        flex: 1;
        max-width: var(--measure);
        margin: 0 auto;
        padding: 3rem 1.5rem;
        width: 100%;
      }

      footer {
        border-top: 1px solid var(--color-border);
        padding: 1.5rem 2rem;
        font-family: var(--font-meta);
        font-size: 0.8rem;
        color: var(--color-muted);
      }

      footer a {
        color: var(--color-muted);
      }

      a {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      h1, h2, h3 {
        font-family: var(--font-meta);
        line-height: 1.25;
        letter-spacing: -0.01em;
      }

      h1 { font-size: 1.9rem; }
      h2 { font-size: 1.25rem; margin-top: 2.5rem; }
      h3 { font-size: 1.05rem; }

      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
      }

      pre {
        background: #f3f3ef;
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        font-size: 0.85rem;
      }

      hr {
        border: 0;
        border-top: 1px solid var(--color-border);
        margin: 2.5rem 0;
      }
    </style>
  </body>
</html>
