---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"cases">;
}

const { entry } = Astro.props;
const { data } = entry;

const dateFormatted = data.date.toLocaleDateString(data.language, {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const siteUrl = Astro.site?.toString() ?? "";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const jsonUrl = new URL(`/cases/${entry.slug}.json`, Astro.site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonical}#article`,
      headline: data.title,
      description: data.summary,
      datePublished: data.date.toISOString(),
      inLanguage: data.language,
      url: canonical,
      isAccessibleForFree: true,
      author: { "@type": "Person", name: data.human },
      creator: [
        { "@type": "Person", name: data.human },
        { "@type": "SoftwareApplication", name: data.model },
      ],
      keywords: [
        ...data.domain,
        data.problem_type,
        ...data.ai_role,
        ...data.human_role,
      ].join(", "),
      mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
      isPartOf: { "@type": "WebSite", "@id": `${siteUrl}#website`, name: "ai-notes" },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "ai-notes",
          item: siteUrl,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: data.title,
          item: canonical,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${data.title} — ai-notes`}
  description={data.summary}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={data.date.toISOString()} />
    <meta property="article:author" content={data.human} />
    <link rel="alternate" type="application/json" title="Case file JSON" href={jsonUrl} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>
  <article>
    <header class="case-header">
      <p class="meta">
        <time datetime={data.date.toISOString()}>{dateFormatted}</time>
        <span>&middot;</span>
        <span>{data.domain.join(" · ")}</span>
        <span>&middot;</span>
        <span>{data.problem_type}</span>
      </p>
      <h1>{data.title}</h1>
      <p class="summary">{data.summary}</p>
    </header>

    <aside class="transparency">
      <h2>Transparency</h2>
      <dl>
        <dt>Model</dt>
        <dd>{data.model}</dd>
        <dt>Human curator</dt>
        <dd>{data.human}</dd>
        <dt>Correction level</dt>
        <dd>{data.correction_level}</dd>
        <dt>Anonymized</dt>
        <dd>{data.anonymized ? "yes" : "no"}</dd>
      </dl>
    </aside>

    <div class="content">
      <slot />
    </div>
  </article>

  <style>
    .case-header {
      margin-bottom: 2.5rem;
    }

    .meta {
      font-family: var(--font-meta);
      font-size: 0.85rem;
      color: var(--color-muted);
      margin: 0 0 0.5rem 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .summary {
      font-size: 1.1rem;
      color: var(--color-muted);
      font-style: italic;
      margin-top: 0.75rem;
    }

    .transparency {
      background: #f3f3ef;
      border-left: 3px solid var(--color-accent);
      padding: 1rem 1.25rem;
      margin: 0 0 2.5rem 0;
      font-family: var(--font-meta);
      font-size: 0.85rem;
    }

    .transparency h2 {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0 0 0.75rem 0;
      color: var(--color-muted);
    }

    .transparency dl {
      margin: 0;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.25rem 1rem;
    }

    .transparency dt {
      color: var(--color-muted);
    }

    .transparency dd {
      margin: 0;
      color: var(--color-fg);
    }
  </style>
</BaseLayout>
